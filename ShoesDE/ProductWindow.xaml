<Window x:Class="ShoesDE.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesDE"
        mc:Ignorable="d"
        Title="Продукты" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="17*"/>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="FullUserName"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="20 10"/>
        <ScrollViewer Grid.Row="1">

            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="80"
                                        Height="80"
                                        Margin="15 0">
                                    <Image Source="{Binding Photo}"/>

                                </Border>
                                <StackPanel Grid.Row="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>

                                    </TextBlock>
        
                                    
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                        
                        
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
        </ScrollViewer>
        <Button Name="LogOutButton"
                Content="ВЫЙТИ"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Click="LogOutButton_Click"/>

    </Grid>
</Window>
