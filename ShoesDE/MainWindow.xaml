<Window x:Class="ShoesDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesDE"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800">
    <Grid>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <StackPanel Margin="140,140,140,47">

            <TextBlock Text="Авторизация"
                           Margin="20 10" Width="124"/>
            
            <TextBox  Name="LoginEnter"
                         Margin="20 10" Width="291" />

            <PasswordBox Name="PasswordEnter"
                         Margin="20 10" Width="299"/>

            <Button Name="LogInButton"
                    Content="Войти"
                    Width="305"
                    Margin="40 10"
                    Click="LogInButton_Click"/>
            
            <Button Content="Войти как Гость"
                    Name="Gosti"
                    Width="304"
                    Click="Gosti_Click"
                    />
        </StackPanel>
    </Grid>
</Window>
